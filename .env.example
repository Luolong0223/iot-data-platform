# 数据库配置（优先使用 DATABASE_URL，否则读取以下字段）
DATABASE_URL=
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=iot-platform
MYSQL_PASSWORD=
MYSQL_DATABASE=iot-platform

# Flask 密钥（生产环境必须设置，否则每次重启 session 失效）
SECRET_KEY=

# TCP 服务端口
TCP_BASE_PORT=9105

# 管理员默认账号（首次部署时使用）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# 邮件（可选）
MAIL_SERVER=
MAIL_PORT=465
MAIL_USERNAME=
MAIL_PASSWORD=

# 钉钉机器人（可选）
DINGTALK_WEBHOOK=
DINGTALK_SECRET=

# 企业微信机器人（可选）
WECOM_WEBHOOK=

# 地图（可选）
BAIDU_MAP_AK=

# Session 安全
SESSION_COOKIE_SECURE=false

# 日志级别
LOG_LEVEL=INFO
